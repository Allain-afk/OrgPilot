// OrgPilot - The Southern Scholar — USPF Student Publication
// Prisma schema — SQLite-compatible, portable to Postgres
// No enum keyword (SQLite limitation) — use String + TypeScript unions

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ──────────────────────────────────────────────
// User — Publication staff members
// ──────────────────────────────────────────────
model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  role      String   @default("WRITER") // EDITOR_IN_CHIEF | ASSOCIATE_EDITOR | MANAGING_EDITOR | HEAD_EDITORIALS | HEAD_FEATURES_MARKETING | WRITER | PHOTOJOURNALIST | LAYOUT_ARTIST | ADVISER | ADMIN
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tasks Task[]
}

// ──────────────────────────────────────────────
// Task — Core work item managed by the agents
// ──────────────────────────────────────────────
model Task {
  id           String    @id @default(uuid())
  title        String
  description  String
  type         String    @default("OTHER")    // STORY_PITCH | ARTICLE_ASSIGNMENT | ARTICLE_REVIEW | LAYOUT_REQUEST | PHOTO_ASSIGNMENT | EVENT_COVERAGE | PUBLICATION_ISSUE | SOCIAL_MEDIA_POST | TEAM_TASK | OTHER
  status       String    @default("NEW")      // NEW | IN_PROGRESS | BLOCKED | DONE | CANCELLED
  priority     String    @default("MEDIUM")   // LOW | MEDIUM | HIGH | URGENT
  section      String?                        // NEWS | FEATURES | OPINION | SPORTS | LIFESTYLE | PHOTOGRAPHY | LAYOUT
  ownerId      String?
  dueDate      DateTime?
  sourceSystem String    @default("MANUAL")   // FORM | EMAIL | MANUAL
  sourceId     String    @default("")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  owner User?           @relation(fields: [ownerId], references: [id])
  logs  AgentActionLog[]
}

// ──────────────────────────────────────────────
// AgentActionLog — Audit trail of agent actions
// ──────────────────────────────────────────────
model AgentActionLog {
  id                String   @id @default(uuid())
  taskId            String?
  agentId           String   @default("MASTER") // MASTER | EDITORIAL | PRODUCTION | OPERATIONS
  eventType         String   // INGEST_EVENT | TASK_UPDATE | NOTIFICATION | APPROVAL_REQUEST | AGENT_REASONING
  rawEvent          String   @default("{}") // JSON stored as text for portability
  actionDescription String
  autoExecuted      Boolean  @default(true)
  proposedChanges   String?  // JSON — only for APPROVAL_REQUEST
  createdAt         DateTime @default(now())

  task Task? @relation(fields: [taskId], references: [id])
}
